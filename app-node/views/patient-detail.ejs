<%- include('partials/header') %>

    <header>
        <a href="/patients"
            style="color:var(--accent); text-decoration:none; font-size:0.9rem; font-weight:600; display:inline-flex; align-items:center; gap:8px;">
            <span style="font-size: 1.2rem;">&larr;</span> Back to Explorer
        </a>
        <h2 style="margin-top:1rem; display: flex; align-items: center; gap: 12px;">
            <%= patient.full_name %>
                <span
                    style="font-size: 0.7rem; color: var(--text-secondary); font-weight: 500; border: 1px solid var(--border); padding: 2px 8px; border-radius: 4px;">SQL
                    REGISTRY</span>
        </h2>
    </header>

    <div class="hybrid-grid">
        <aside-content>
            <div class="card">
                <h3
                    style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent);">
                    Demographics
                    <span style="font-size: 0.65rem; color: var(--text-secondary); font-weight: 500;">MYSQL</span>
                </h3>
                <ul class="admin-list">
                    <li><label>Patient ID</label> <span>#<%= patient.patient_id %></span></li>
                    <li><label>D.O.B</label> <span>
                            <%= new Date(patient.date_of_birth).toLocaleDateString() %>
                        </span></li>
                    <li><label>Gender</label> <span>
                            <%= patient.gender %>
                        </span></li>
                    <li><label>Blood Type</label> <span class="badge badge-success">
                            <%= patient.blood_type %>
                        </span></li>
                    <li><label>Contact</label> <span>
                            <%= patient.phone || 'N/A' %>
                        </span></li>
                    <li style="flex-direction: column; align-items: flex-start; gap: 4px;">
                        <label>Email Address</label>
                        <span style="font-size: 0.9rem; color: var(--accent);">
                            <%= patient.email %>
                        </span>
                    </li>
                </ul>
            </div>
        </aside-content>

        <div class="main-clinical">
            <h3 style="margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between;">
                Clinical History
                <span
                    style="font-size: 0.7rem; color: var(--text-secondary); font-weight: 500; border: 1px solid var(--border); padding: 2px 10px; border-radius: 4px; background: var(--primary-bg);">MONGODB</span>
            </h3>

            <% if (records.length===0 && labs.length===0) { %>
                <div class="card" style="text-align: center; padding: 3rem;">
                    <p style="color:var(--text-secondary);">No clinical records or laboratory tests found in MongoDB.
                    </p>
                </div>
                <% } %>

                    <% records.forEach(rec=> { %>
                        <div class="clinical-record">
                            <div
                                style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                                <h4 style="color: var(--text-primary); font-size: 1.15rem;">Visit Record</h4>
                                <span style="font-size: 0.85rem; color: var(--text-secondary);">
                                    <%= new Date(rec.visit_date).toLocaleDateString() %>
                                </span>
                            </div>

                            <div style="margin-bottom: 1.5rem;">
                                <p style="margin-bottom: 0.5rem;"><strong
                                        style="color: var(--accent);">Complaint:</strong>
                                    <%= rec.chief_complaint %>
                                </p>
                                <p><strong>Diagnosis:</strong>
                                    <%= Array.isArray(rec.diagnosis) ? rec.diagnosis.join(', ') : rec.diagnosis %></p>
                </div>

                <% if (rec.vitals) { %>
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
                    <div class="vital-tag"><strong>BP:</strong> <%= rec.vitals.blood_pressure %></div>
                    <div class="vital-tag"><strong>HR:</strong> <%= rec.vitals.heart_rate %> bpm</div>
                    <div class="vital-tag"><strong>WT:</strong> <%= rec.vitals.weight_kg %> kg</div>
                </div>
                <% } %>
            </div>
        <% }) %>

        <% labs.forEach(lab => { %>
            <div class="clinical-record" style="border-left-color: var(--warning);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <h4 style="color: var(--text-primary); font-size: 1.15rem;">Lab: <%= lab.test_name %></h4>
                    <span class="badge badge-warning"><%= lab.status %></span>
                </div>
                <div style="background: rgba(0,0,0,0.03); padding: 1rem; border-radius: 8px; font-family: monospace; font-size: 0.85rem; color: var(--accent);">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                        <% if (lab.results) { %>
                            <% Object.entries(lab.results).forEach(([key, val]) => { %>
                                <span><%= key.toUpperCase() %>:</span>
                                <span style="color: var(--text-primary);"><%= val %></span>
                            <% }) %>
                        <% } else { %>
                            <span style="grid-column: span 2; color: var(--text-secondary);">No results available</span>
                        <% } %>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<%- include('partials/footer') %>